generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  photoUrl  String?
  createdAt DateTime @default(now())
  books     Book[]
}

model Student {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?  @unique
  photoUrl  String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model Book {
  id        Int      @id @default(autoincrement())
  title     String
  author    String
  isbn      String?  @unique
  images    String[]
  stock     Int      @default(0)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  orders    Order[]
  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  APPROVED
  RETURNED
  CANCELLED
}

model Order {
  id         Int         @id @default(autoincrement())
  studentId  Int
  student    Student     @relation(fields: [studentId], references: [id])
  bookId     Int
  book       Book        @relation(fields: [bookId], references: [id])
  status     OrderStatus @default(PENDING)
  orderDate  DateTime    @default(now())
  returnDate DateTime?
  createdAt  DateTime    @default(now())
}

