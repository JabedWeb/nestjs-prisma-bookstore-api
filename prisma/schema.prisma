generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  photoUrl  String?
  createdAt DateTime @default(now())
  books     Book[]
}

model Student {
  id        Int      @id @default(autoincrement())
  name      String
  photoUrl  String?
  email     String   @unique
  createdAt DateTime @default(now())
}

model Book {
  id        Int      @id @default(autoincrement())
  title     String
  author    String
  isbn      String?  @unique
  images    String[]
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}


